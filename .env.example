# Spotify Developer App: https://developer.spotify.com/dashboard
# Redirect URIs (add both in Spotify Dashboard → Settings):
#   http://localhost:3000/api/auth/callback/spotify
#   https://YOUR_VERCEL_DOMAIN/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional on Vercel (auto-set from VERCEL_URL). Required for custom domains:
# AUTH_URL=https://your-domain.vercel.app

# Discogs personal access token: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Optional: Last.fm API key (free) for similar-artist and genre-tag enrichment
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# MusicBrainz and Apple Music (iTunes Search API) need no key — used automatically.

# Database — free local file (no signup required)
DATABASE_URL=file:./data/record_finder.db

# Optional: Turso free tier for persistent credits/orders on Vercel
# https://turso.tech (free — no credit card required)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
